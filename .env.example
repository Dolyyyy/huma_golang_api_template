# HTTP server port (without leading colon)
PORT=8888

# API docs renderer (swagger-ui | stoplight | scalar)
DOCS_RENDERER=swagger-ui

# Logging level: INFO, SUCCESS, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable/disable file logging
LOG_TO_FILE=true

# Log file path (directory is auto-created)
LOG_FILE_PATH=logs/api.log

# Rotation policy
LOG_MAX_SIZE_MB=10
LOG_MAX_BACKUPS=5
LOG_MAX_AGE_DAYS=30
LOG_COMPRESS=true

# Enable ANSI colors in terminal output
LOG_CONSOLE_COLORS=true
